<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:gravity="center_horizontal">

    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="2"/>

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00:00"
        android:textColor="@color/text_primary"
        android:textSize="72sp"
        android:fontFamily="monospace"
        android:includeFontPadding="false"
        android:letterSpacing="0.02"/>

    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="2"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <NumberPicker
                android:id="@+id/npHours"
                android:layout_width="80dp"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_hh"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textSize="30sp"
            android:textColor="@color/text_secondary"
            android:paddingHorizontal="6dp"
            android:paddingBottom="24dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <NumberPicker
                android:id="@+id/npMinutes"
                android:layout_width="80dp"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_mm"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textSize="30sp"
            android:textColor="@color/text_secondary"
            android:paddingHorizontal="6dp"
            android:paddingBottom="24dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <NumberPicker
                android:id="@+id/npSeconds"
                android:layout_width="80dp"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_ss"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Alert mode selector -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alert:"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginEnd="12dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/alertChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVibrate"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vibrate"
                android:checked="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSound"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sound"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBoth"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Both"/>

        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Normal controls (hidden during alert) -->
    <LinearLayout
        android:id="@+id/layoutTimerButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingBottom="40dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="10dp"
            android:text="@string/btn_start"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:backgroundTint="@color/btn_start"/>

        <Button
            android:id="@+id/btnPause"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="10dp"
            android:text="@string/btn_pause"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:backgroundTint="@color/btn_pause"/>

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/btn_reset"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:backgroundTint="@color/btn_reset"/>
    </LinearLayout>

    <!-- Stop alert button (visible only when alert is firing) -->
    <Button
        android:id="@+id/btnStopAlert"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="80dp"
        android:text="Stop"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:backgroundTint="@color/btn_stop_alert"
        android:visibility="gone"/>

</LinearLayout>
